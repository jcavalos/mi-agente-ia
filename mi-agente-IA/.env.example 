# .env - VARIABLES DE ENTORNO
# Copia esto a un archivo llamado ".env" en tu carpeta raíz
# Llena con tus propios valores

# ===== GROQ (LLM Gratis) =====
GROQ_API_KEY=gsk_tu_api_key_aqui

# ===== WHATSAPP (Opcional) =====
WHATSAPP_API_KEY=tu_api_key_whatsapp
WHATSAPP_PHONE_NUMBER_ID=tu_phone_id

# ===== INSTAGRAM (Opcional) =====
INSTAGRAM_API_KEY=tu_api_key_instagram
INSTAGRAM_BUSINESS_ACCOUNT_ID=tu_account_id

# ===== FACEBOOK (Opcional) =====
FACEBOOK_PAGE_ACCESS_TOKEN=tu_token_facebook
FACEBOOK_VERIFY_TOKEN=tu_verify_token

# ===== GOOGLE SHEETS (Opcional) =====
GOOGLE_SHEETS_ID=tu_sheet_id
GOOGLE_CREDENTIALS_JSON=ruta_a_tu_credentials.json

# ===== CONFIGURACIÓN DE APP =====
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# ===== BASE DE DATOS (Opcional) =====
DATABASE_URL=sqlite:///tienda.db
# O para PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/tienda

# ===== OTROS =====
DEBUG=True
